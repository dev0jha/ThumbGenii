# ThumbAI Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=ThumbAI
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database
# For SQLite: sqlite:///./thumbai.db
# For PostgreSQL: postgresql://user:password@localhost:5432/thumbai
DATABASE_URL=sqlite:///./thumbai.db

# Redis (optional - for caching and Celery)
REDIS_URL=redis://localhost:6379/0

# AI APIs
# Get your Grok API key from: https://x.ai
GROK_API_KEY=xai-your-grok-api-key

# OpenAI (optional - for fallback)
OPENAI_API_KEY=sk-your-openai-key

# ImageKit
# Get your keys from: https://imagekit.io
IMAGEKIT_PRIVATE_KEY=your-private-key
IMAGEKIT_PUBLIC_KEY=your-public-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-endpoint

# OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
